DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=certsleuth.com,www.certsleuth.com
DATABASE_URL=postgres://certsleuth:change-me@db:5432/certsleuth
# Local dev fallback: DATABASE_URL=sqlite:///db.sqlite3  (RLS tests require Postgres)
EMAIL_URL=smtp://user:pass@smtp.resend.com:587
DEFAULT_FROM_EMAIL=CertSleuth <no-reply@certsleuth.com>
FIELD_ENCRYPTION_KEY=generate-32-byte-urlsafe-base64   # SEC-009 envelope key (via Secret Manager in prod)
ANTHROPIC_API_KEY=            # server-side steady-state extraction only (D17)
GOOGLE_OAUTH_CLIENT_ID=       # Gmail on-demand scan (D13); blank disables the feature
GOOGLE_OAUTH_CLIENT_SECRET=
